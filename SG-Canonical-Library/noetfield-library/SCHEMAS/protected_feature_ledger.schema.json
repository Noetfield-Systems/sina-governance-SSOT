{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtectedFeatureLedger",
  "type": "object",
  "required": [
    "system",
    "protected_features",
    "explicit_removals",
    "verification_checks"
  ],
  "properties": {
    "system": {
      "type": "string"
    },
    "protected_features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "explicit_removals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}