{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "p0-pgr/P0_PROMPT_PACKET_SCHEMA_v1.json",
  "title": "P0 prompt packet v1.1 (delivery-aware)",
  "type": "object",
  "required": [
    "schema",
    "packet_id",
    "created_at",
    "mission",
    "problem_statement",
    "deliverable",
    "route",
    "gates",
    "roi",
    "evidence_required",
    "confidence",
    "status"
  ],
  "properties": {
    "schema": { "const": "p0_prompt_packet_v1.1" },
    "packet_id": { "type": "string", "pattern": "^PKT-[0-9]{4}(-[a-z0-9-]+)?$" },
    "created_at": { "type": "string", "description": "machine-generated ISO-8601 UTC" },
    "mission": { "type": "string", "minLength": 8 },
    "problem_statement": { "type": "string", "minLength": 8 },
    "deliverable": {
      "type": "object",
      "required": ["type", "destination", "acceptance"],
      "properties": {
        "type": { "type": "string" },
        "destination": { "type": "string" },
        "acceptance": { "type": "string", "minLength": 8 }
      }
    },
    "route": {
      "type": "string",
      "enum": ["CLOUD_WORKER", "CLOUD_RESEARCH", "SESSION_EMBEDDED", "REVIEW_QUEUE"]
    },
    "gates": {
      "type": "object",
      "required": [
        "cloud_only",
        "read_only_or_reversible",
        "roi_positive",
        "no_deploy",
        "no_external_send",
        "no_legal_financial_commitment",
        "no_p0_leakage",
        "no_authority_change",
        "founder_authorization_receipt"
      ],
      "additionalProperties": { "type": ["boolean", "string"] }
    },
    "roi": {
      "type": "object",
      "required": ["revenue", "trust", "workload_relief", "cloud_now", "reversibility", "rationale"],
      "properties": {
        "revenue": { "type": "number", "minimum": 0, "maximum": 5 },
        "trust": { "type": "number", "minimum": 0, "maximum": 5 },
        "workload_relief": { "type": "number", "minimum": 0, "maximum": 5 },
        "cloud_now": { "type": "number", "minimum": 0, "maximum": 5 },
        "reversibility": { "type": "number", "minimum": 0, "maximum": 5 },
        "rationale": { "type": "string" }
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "evidence_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "confidence": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "OUTBOX", "ROUTED", "HOLD_CLOUD_UNSAFE", "QUEUED_FOUNDER_REVIEW", "DONE", "KILLED"]
    },
    "labels": { "type": "array", "items": { "type": "string" } },
    "source_findings": { "type": "array", "items": { "type": "string" } }
  }
}
