{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "noetfield:p0pgr:prompt-registry:v1",
  "title": "P0-PGR Prompt Registry v1",
  "description": "Catalog of reusable prompt templates and their live usage stats — the packet factory's memory (move M07 output target). Every recurring problem class gets ONE registered template; ad-hoc re-authoring of a registered class is a defect. Registry file lives at data/p0pgr_prompt_registry_v1.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "updated_at", "templates"],
  "properties": {
    "schema": { "const": "p0pgr-prompt-registry-v1" },
    "version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "problem_class", "lane", "status", "packet_defaults", "evidence_basis", "lint_status"],
        "properties": {
          "template_id": { "type": "string", "pattern": "^TPL-[a-z0-9-]+-v[0-9]+$" },
          "title": { "type": "string" },
          "problem_class": {
            "enum": ["blocker", "repair", "verification", "revenue", "hygiene", "research", "deploy", "architecture", "founder_escalation"]
          },
          "lane": { "enum": ["SourceA", "NOOS", "SG", "TrustField", "Noetfield", "Revenue", "Ops"] },
          "status": {
            "enum": ["DRAFT", "SHADOW_APPROVED", "AUTO_DISPATCH_APPROVED", "RETIRED"],
            "description": "AUTO_DISPATCH_APPROVED is founder-gated; it is the unit of Phase-3 autonomy — autonomy is granted per-template, never globally."
          },
          "packet_defaults": {
            "type": "object",
            "description": "Field defaults merged into compiled packets (execution_mode, delivery_route, target_executor, model_tier, cost_limit_usd, quality_handling, constraints, forbidden_actions...). Parameter slots use {{slot_name}}.",
            "required": ["execution_mode", "authority_scope", "model_tier", "cost_limit_usd"],
            "properties": {
              "execution_mode": { "enum": ["CLOUD_ONLY", "HYBRID_MAC", "HUMAN_REVIEW", "FOUNDER_ONLY"] },
              "authority_scope": { "enum": ["observe", "edit", "test", "commit", "deploy", "blocked"] },
              "model_tier": { "enum": ["cheap", "capable", "premium"] },
              "cost_limit_usd": { "type": "number", "exclusiveMinimum": 0 }
            },
            "additionalProperties": true
          },
          "parameter_slots": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "description"],
              "properties": {
                "name": { "type": "string" },
                "description": { "type": "string" },
                "example": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "evidence_basis": {
            "type": "array", "minItems": 2,
            "items": { "type": "string" },
            "description": "≥2 historical receipts proving this problem class recurs (M07 rule). A template without recurrence evidence is speculation."
          },
          "lint_status": {
            "type": "object",
            "required": ["verdict", "linted_at"],
            "properties": {
              "verdict": { "enum": ["PASS", "REPAIR_CANDIDATE"] },
              "linted_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          },
          "p0_fingerprint_sweep": {
            "type": "object",
            "properties": {
              "leaks_found": { "type": "integer", "minimum": 0 },
              "swept_at": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          },
          "usage_stats": {
            "type": "object",
            "description": "Updated by Harvest, never hand-edited. Feeds ROI Judge: templates with poor accept-rate get demoted, not silently re-tuned.",
            "properties": {
              "packets_compiled": { "type": "integer", "minimum": 0 },
              "accepted": { "type": "integer", "minimum": 0 },
              "rejected": { "type": "integer", "minimum": 0 },
              "founder_rewrites": { "type": "integer", "minimum": 0 },
              "total_cost_usd": { "type": "number", "minimum": 0 },
              "last_used": { "type": "string", "format": "date-time" }
            },
            "additionalProperties": false
          },
          "founder_approval_ref": {
            "type": "string",
            "description": "Required when status is AUTO_DISPATCH_APPROVED — path to founder receipt."
          }
        }
      }
    }
  }
}
