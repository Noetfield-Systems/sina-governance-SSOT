      "superseded incorrectly": -18
    },
    "neutral": {
      "initial": 0,
      "initial draft": 0,
      "initial spec": 0,
      "formatting": 2,
      "added": 5
    }
  },
  "quality_bands": {
    "good_min": 15,
    "bad_max": -10,
