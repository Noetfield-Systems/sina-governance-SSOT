    "AWAITING_LIBRARY_UPLOAD": "Placeholder or draft exists — canonical library copy not installed yet",
    "PENDING_FOUNDER": "Founder action required before thread can close",
    "PENDING_THREAD": "Blocked on another thread ratification or merge",
    "IN_PROGRESS": "Active edit trail but not yet final",
    "LEFT_ABANDONED": "Superseded undated/stale copies only — work moved elsewhere",
    "STALE_DUPLICATE": "Duplicate copy with no unique progress"
  },
