    "conflict_log": {"rank": 3, "description": "Logged conflict / clarification thread"},
    "implementation_prompt": {"rank": 4, "description": "Execution companion derived from a spec"},
    "discovery_report": {"rank": 5, "description": "Research / inventory output"},
    "prompt_companion": {"rank": 6, "description": "Prompt pack companion in Prompts folder"},
    "duplicate_copy": {"rank": 99, "description": "Finder duplicate or stale copy"}
  },
  "completion_states": {
    "COMPLETED": "Final carrier chosen; no open founder gate; no blocking thread dependency",
    "AWAITING_REGISTRY_ENTRY": "New draft ready — waiting for SG registry + library promote",
