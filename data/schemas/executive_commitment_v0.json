{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Commitment",
  "type": "object",
  "required": [
    "schema",
    "commitment_id",
    "version",
    "decision_id",
    "goal_id",
    "owner",
    "required_artifact",
    "status",
    "created_at"
  ],
  "properties": {
    "schema": {
      "const": "noetfield.executive.commitment.v0"
    },
    "commitment_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "goal_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "due_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_artifact": {
      "type": "string"
    },
    "status": {
      "enum": [
        "OPEN",
        "BLOCKED",
        "STALLED",
        "CLOSED",
        "OVERDUE"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "max_silence_minutes": {
      "type": "number"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
