{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FounderDecisionPacket",
  "type": "object",
  "required": [
    "schema",
    "packet_id",
    "topic",
    "options",
    "sg_recommendation",
    "created_at"
  ],
  "properties": {
    "schema": {
      "const": "noetfield.executive.founder_decision_packet.v0"
    },
    "packet_id": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "what_changed": {
      "type": "string"
    },
    "options": {
      "type": "array"
    },
    "sg_recommendation": {
      "type": "string"
    },
    "critic_view": {
      "type": "string"
    },
    "risk_if_delayed": {
      "type": "string"
    },
    "safest_interim_action": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}
