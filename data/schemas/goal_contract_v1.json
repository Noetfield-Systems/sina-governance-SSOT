{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noetfield.systems/schemas/goal_contract_v1.json",
  "title": "Goal Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "goal_id",
    "owner",
    "goal_version",
    "intent",
    "acceptance_predicates",
    "scope_allowlist",
    "forbidden_effects",
    "budgets",
    "evidence_required",
    "stop_policy",
    "authority_hash"
  ],
  "properties": {
    "schema": { "const": "noetfield.goal_contract.v1" },
    "goal_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "goal_version": { "type": "integer", "minimum": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "acceptance_predicates": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope_allowlist": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_effects": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_attempts",
        "max_children",
        "max_minutes",
        "max_cost_usd",
        "max_human_tax_units"
      ],
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "max_children": { "type": "integer", "minimum": 0 },
        "max_minutes": { "type": "number", "minimum": 1 },
        "max_cost_usd": { "type": "number", "minimum": 0 },
        "max_human_tax_units": { "type": "number", "minimum": 0 }
      }
    },
    "evidence_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "git_diff",
          "test_result",
          "rendered_artifact",
          "receipt",
          "http_check",
          "artifact_check"
        ]
      }
    },
    "stop_policy": {
      "type": "string",
      "enum": ["STOP_AND_INCIDENT", "STOP_AND_RED_ZONE", "STOP_ONLY"]
    },
    "authority_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
