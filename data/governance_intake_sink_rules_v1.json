        "COPILOT_AUTOMATION_COST_PROFILE_LOCKED_v1.md"
      ],
      "noos-control-desk-v2": [
        "cost-production-law/control-desk/README.md",
        "control-desk/README.md"
      ],
      "founder-intent-filter-v1": [
        "founder-intent-filter/FOUNDER_INTENT_FILTER.md",
        "FOUNDER_INTENT_FILTER.md"
      ]
    }
  },

  "artifact_signatures": {
