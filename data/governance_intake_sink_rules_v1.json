  "path_rubric": "data/governance_intake_path_rubric_v1.json",
  "design_note": "Folder names (e.g. Tag in Raw AI test) are NOT rules. Evidence sink + artifact signatures are rules.",

  "sink_detection": {
    "method": "evidence_aggregate",
    "source": "governance_intake_path_intelligence_v1.detect_probable_final_folder",
    "min_confidence": 0.5,
    "include_ranked_within_margin": 0.7,
    "max_sink_dirs": 3,
    "fallback": "intake_root"
  },

  "scan_scope": {
    "file_types": [".md", ".zip"],
    "scan_sink_dirs": true,
    "scan_intake_root_md": true,
    "root_md_patterns": [
      "^SMART_PRODUCTION.*\\.md$",
      "^NOETFIELD_COHERENT.*\\.md$",
      "^COPILOT_AUTOMATION.*\\.md$",
      "^CANONICAL_D4_PACKAGE.*\\.md$"
    ]
  },

  "exclude_path_parts": [
    "/tests/",
    "/fixtures/",
    "/test/",
    "/prompts/",
    "/prompts ",
    "/.venv/",
    "/site-packages/"
  ],

  "exclude_name_patterns": [
    "deep-research",
    "deep_research",
    "discovery report prompt",
    "linkedin-profile"
  ],

  "exclude_filename_regex": " \\\\d+\\\\.(md|zip)$",

  "zip_bundle_rules": {
    "zip_name_hints": ["control-desk", "smart-production", "founder-intent", "cost-production", "cost-law"],
    "zip_priority_tokens": {
      "patched": 100,
      "batch": 70,
      "mvp": 50,
      "v2": 30
    },
    "inner_paths_by_artifact": {
      "smart-production-cost-law-v2": [
        "cost-production-law/SMART_PRODUCTION_COST_LAW_v2.md",
        "SMART_PRODUCTION_COST_LAW_v2.md"
