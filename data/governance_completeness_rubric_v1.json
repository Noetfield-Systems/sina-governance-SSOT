    "void_if_completeness_below_primary_by": 25,
    "void_if_progress_below_primary_by": 20,
    "conflict_review_on_opposing_markers": true
  },
  "opposing_markers": [
    ["must", "must not"],
    ["active", "superseded"],
    ["allow", "forbidden"],
    ["yes", "no"]
