{
  "schema": "nf.commissioning-specialist.map.v1",
  "version": "2.2.0",
  "loop_id": "nf-commissioning-specialist-tick-v1",
  "trigger_host": "on_demand",
  "cadence_cron": null,
  "interval_minutes": null,
  "trigger": {
    "mode": "on_demand",
    "endpoint": "POST /jobs",
    "auth": "Bearer COMMISSIONING_TRIGGER_SECRET",
    "durable_workflow": "nf-commissioning-job-v1",
    "requires_explicit_job": true,
    "requires_request_id": true
  },
  "receipt_path": "receipts/doctrine/NF_COMMISSIONING_SPECIALIST_TICK_*.json",
  "law": [
    "Observe -> Detect -> Critique -> Repair -> ProposeImprove -> ReObserve",
    "Machine may repair only allowlisted actions",
    "Machine may PROPOSE improvements only; founder ratifies architecture (no unsupervised redesign)",
    "AUTONOMOUS_PRODUCTION_MUTATIONS=hold until founder lifts",
    "Unknown task_kind routes to T0 deterministic",
    "Each explicit run names one unfinished or invalidated job and must deliver real evidence for that job",
    "Completed unchanged jobs are not repeated on a timer",
    "Never stamp fully_commissioned while runtime_reality says not_commissioned"
  ],
  "skills": [
    "commissioning-specialist",
    "staleness-gate-auditor",
    "receipt-ledger-auditor",
    "registry-scheduler-and-executor-validator"
  ],
  "closed_loop_stages": [
    {
      "id": "observe",
      "tier": "T0",
      "actions": [
        "probe_surfaces",
        "read_runtime_reality_flags",
        "read_last_receipt",
        "load_job_progress"
      ]
    },
    {
      "id": "detect",
      "tier": "T0",
      "actions": [
        "diff_expected_vs_actual",
        "staleness_check",
        "secret_presence_check",
        "validate_explicit_job_and_idempotency_key"
      ]
    },
    {
      "id": "critique",
      "tier": "T1",
      "actions": [
        "classify_defect",
        "rank_severity",
        "choose_repair_or_propose",
        "plan_job_execution"
      ],
      "models": [
        "deepseek_flash",
        "deepseek_pro",
        "glm",
        "kimi"
      ]
    },
    {
      "id": "repair",
      "tier": "T0",
      "actions": [
        "allowlisted_heal_only",
        "execute_or_dispatch_selected_job",
        "persist_explicit_job_result"
      ],
      "requires_founder_approval": false
    },
    {
      "id": "propose_improve",
      "tier": "T2",
      "actions": [
        "emit_kaizen_proposal"
      ],
      "requires_founder_ratification": true,
      "models": [
        "deepseek_flash",
        "deepseek_pro",
        "glm",
        "kimi",
        "huggingface"
      ]
    },
    {
      "id": "reobserve",
      "tier": "T0",
      "actions": [
        "write_receipt",
        "upsert_last_fired_at",
        "persist_job_progress"
      ]
    }
  ],
  "surfaces": [
    {
      "id": "sg_shadow",
      "url": "https://noetfield-sg-authority-v2-shadow.kazemnezhadsina144.workers.dev/health",
      "expect": {
        "ok": true,
        "mode": "shadow"
      }
    },
    {
      "id": "sg_runtime_truth",
      "kind": "github_raw",
      "repo": "Noetfield-Systems/sina-governance-SSOT",
      "path": "data/runtime_reality_v1.json",
      "expect_keys": [
        "authority.autonomous_production_mutations=HOLD"
      ]
    },
    {
      "id": "key_pointer",
      "kind": "github_raw",
      "repo": "Noetfield-Systems/sina-governance-SSOT",
      "path": "data/sg_authority_key_pointer_v1.json",
      "expect": {
        "exists": true
      }
    },
    {
      "id": "job_queue",
      "kind": "github_raw",
      "repo": "Noetfield-Systems/sina-governance-SSOT",
      "path": "data/nf_commissioning_job_queue_v1.json",
      "expect": {
        "exists": true
      }
    }
  ],
  "repair_allowlist": [
    {
      "id": "reprobe_shadow",
      "description": "Re-GET shadow health and record"
    },
    {
      "id": "upsert_loop_liveness",
      "description": "Write last_fired_at to KV/loop registry"
    },
    {
      "id": "clear_false_live_claim",
      "description": "If truth file claims LIVE while worker 404, flag defect (no auto-edit of main)"
    },
    {
      "id": "dispatch_workflow_job",
      "description": "Cloudflare Workflow dispatches exactly one allowlisted GitHub Actions workflow for an execute-class job"
    },
    {
      "id": "persist_job_progress",
      "description": "Write explicit job progress and request identity to KV"
    },
    {
      "id": "score_runtime_gaps",
      "description": "Deterministic score of proof-a/b and custody gaps from runtime_reality"
    }
  ],
  "repair_forbidden": [
    "mint_new_github_app_private_key",
    "lift_HOLD",
    "enable_enforcement",
    "production_deploy",
    "architecture_redesign",
    "merge_to_main_without_pr",
    "fake_fully_commissioned"
  ],
  "improve_map": {
    "queue": "kaizen",
    "max_proposals_per_tick": 1,
    "roi_rank": true,
    "machine_safe_only_until_ratified": true,
    "proposal_schema": "nf.kaizen-proposal.v1",
    "ratification": "founder"
  },
  "model_router": {
    "default_tier": "T0",
    "providers": {
      "deepseek_flash": {
        "env": "DEEPSEEK_API_KEY",
        "base": "https://api.deepseek.com/v1/chat/completions",
        "model": "deepseek-v4-flash",
        "thinking": "disabled",
        "max_output_tokens": 500,
        "input_per_million_usd": 0.14,
        "output_per_million_usd": 0.28
      },
      "deepseek_pro": {
        "env": "DEEPSEEK_API_KEY",
        "base": "https://api.deepseek.com/v1/chat/completions",
        "model": "deepseek-v4-pro",
        "thinking": "enabled",
        "max_output_tokens": 1500,
        "input_per_million_usd": 0.435,
        "output_per_million_usd": 0.87
      },
      "glm": {
        "env": "GLM_API_KEY",
        "base": "https://api.z.ai/api/paas/v4/chat/completions",
        "model": "glm-5.2"
      },
      "kimi": {
        "env": "MOONSHOT_API_KEY",
        "base": "https://api.moonshot.ai/v1/chat/completions",
        "model": "kimi-k2.7-code"
      },
      "huggingface": {
        "env": "HF_TOKEN",
        "base": "https://router.huggingface.co/v1/chat/completions",
        "model": "Qwen/Qwen2.5-7B-Instruct"
      }
    },
    "failover_order": [
      "deepseek_flash",
      "deepseek_pro",
      "glm",
      "kimi",
      "huggingface"
    ],
    "max_llm_calls_per_job": 2,
    "max_output_tokens_per_call": 1500,
    "cost_basis": "provider usage tokens times configured current model rates; null when a provider rate is not configured",
    "on_all_fail": "continue_T0_deterministic"
  },
  "job_queue_ref": "data/nf_commissioning_job_queue_v1.json"
}
