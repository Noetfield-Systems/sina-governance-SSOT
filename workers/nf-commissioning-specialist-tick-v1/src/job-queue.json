    {
      "id": "commissioning_directive_rollup",
      "class": "qualify",
      "machine_safe": true,
      "acceptance": "roll up directive; refuse fully_commissioned while any not_commissioned",
      "runway_action": "rollup_commissioning_directive",
      "dispatch": null
    }
  ]
}
