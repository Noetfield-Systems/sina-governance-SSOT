      "runway_action": "score_event_gateway",
      "dispatch": null,
      "founder_gate_if": "event_gateway_not_commissioned"
    },
    {
      "id": "credential_bootstrap_gap",
      "class": "qualify",
      "machine_safe": true,
      "acceptance": "score bootstrap key1 revoke gap",
      "runway_action": "score_credential_bootstrap",
      "dispatch": null,
      "founder_gate_if": "bootstrap_key1_not_revoked"
