{
  "name": "sg-authority-v2-shadow",
  "version": "1.0.0",
  "description": "Non-commissioned deterministic SG v2 shadow evaluator",
  "scripts": {
    "types": "wrangler types --env-file .dev.vars.example --strict-vars false",
    "types:check": "wrangler types --env-file .dev.vars.example --strict-vars false --check",
    "typecheck": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit",
    "test": "vitest run",
    "dry-run": "wrangler deploy --dry-run --outdir dist"
  },
  "license": "UNLICENSED",
  "type": "module",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260718.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "private": true
}
